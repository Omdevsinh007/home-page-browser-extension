{
  "name": "Custom Homepage",
  "version": "2.2.1",
  "manifest_version": 3,
  "description": "A custom landing page instead of the default new tab.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "assets/images/favicon16x16.ico",
    "48": "assets/images/favicon48x48.ico",
    "128": "assets/images/favicon128x128.ico",
    "256": "assets/images/favicon256x256.ico"
  }
}
